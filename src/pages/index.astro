---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wes Foster</title>
  <meta name="description" content="Army veteran, entrepreneur, and agency founder. Building WESFED, ClawDeploy, AI Agent Lab, and Peak Agency Systems." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Wes Foster",
    "alternateName": ["realwesfoster", "wesf90", "wesfed"],
    "url": "https://wesfoster.com",
    "image": "https://wesfoster.com/wes.jpg",
    "jobTitle": "Entrepreneur, Agency Founder, Digital Marketer",
    "description": "Army veteran and entrepreneur. Founder of WESFED digital marketing agency. Builder of AI Agent Lab, Peak Agency Systems, and ClawDeploy. Speaker, marketer, and agency growth coach based in Clarksville, TN.",
    "address": { "@type": "PostalAddress", "addressLocality": "Clarksville", "addressRegion": "TN", "addressCountry": "US" },
    "alumniOf": [{ "@type": "EducationalOrganization", "name": "Grantham University" }],
    "knowsAbout": ["Digital Marketing","Agency Growth","SEO","PPC","AI Agents","Marketing Automation","Entrepreneurship","MRR Growth","Agency Systems","Web Development"],
    "sameAs": [
      "https://x.com/realwesfoster",
      "https://linkedin.com/in/wesfoster",
      "https://github.com/wesf90",
      "https://facebook.com/realwesfoster",
      "https://youtube.com/@wesfosterpeak",
      "https://wesfed.com",
      "https://themondayreset.com"
    ],
    "founder": [{ "@type": "Organization", "name": "WESFED", "url": "https://wesfed.com", "description": "Digital marketing agency founded in 2008, headquartered in Clarksville, TN. Privately valued at over $3 million." }],
    "memberOf": [{ "@type": "Organization", "name": "United States Army", "description": "Combat Infantry Team Leader, deployed to Afghanistan 2010-2011" }]
  }
  </script>
  <script is:inline>
    (function() {
      var t = localStorage.getItem('wf-theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>

  <ThemeToggle />

  <!-- ── Hero ── -->
  <header class="hero">
    <img src="/wes.jpg" alt="Wes Foster" class="hero-photo" width="76" height="76" />
    <div class="hero-text">
      <p class="hero-name">Wes Foster</p>
      <p class="hero-tagline">veteran · marketer · builder · agency founder</p>
      <div class="hero-stats">
        <span class="hero-stat"><strong>15+ yrs</strong> in business</span>
        <span class="hero-stat"><strong>$3M+</strong> agency valuation</span>
        <span class="hero-stat"><strong>2,000+</strong> community members</span>
        <span class="hero-stat"><strong>Top 5%</strong> StackOverflow</span>
      </div>
      <p class="hero-bio">
        Army veteran and founder of <a href="https://wesfed.com" target="_blank" rel="noopener">WESFED</a>.
        I help agency operators grow their MRR, build AI tools for founders, and write about
        what I learn along the way. Based in Clarksville, TN.
      </p>
      <p class="hero-speaking">
        Open to speaking and podcast appearances —
        <a href="mailto:wes@wesfed.com">wes@wesfed.com</a>
      </p>
    </div>
  </header>

  <main>

    <!-- ── Projects ── -->
    <section class="section">
      <p class="sec-label">Projects</p>
      <div class="card-grid">

        <a href="https://wesfed.com" target="_blank" rel="noopener" class="card">
          <span class="ctag">Agency</span>
          <span class="cname">WESFED</span>
          <span class="cdesc">Digital marketing agency — SEO, PPC, web — founded 2008, based in Clarksville, TN.</span>
        </a>

        <a href="https://clawdeploy.com" target="_blank" rel="noopener" class="card">
          <span class="ctag">SaaS</span>
          <span class="cname">ClawDeploy</span>
          <span class="cdesc">OpenClaw-as-a-Service. Deploy and manage instances without the setup headache.</span>
        </a>

        <a href="https://skool.com/aiagentlab" target="_blank" rel="noopener" class="card">
          <span class="ctag">Community · Free</span>
          <span class="cname">AI Agent Lab</span>
          <span class="cdesc">Free community for agency owners learning to build with AI agents and automation.</span>
        </a>

        <a href="https://peakagencysystems.com/slack26" target="_blank" rel="noopener" class="card">
          <span class="ctag">Community · Paid</span>
          <span class="cname">Peak Agency Systems</span>
          <span class="cdesc">The community and coaching program for agency operators scaling with the PEAK Model.</span>
        </a>

        <a href="https://themondayreset.com" target="_blank" rel="noopener" class="card card-full">
          <span class="ctag">Newsletter</span>
          <span class="cname">The Monday Reset</span>
          <span class="cdesc">Weekly newsletter for agency operators. Practical takes on growth, systems, and AI — no fluff.</span>
        </a>

      </div>
    </section>

    <!-- ── Content ── -->
    <section class="section">
      <p class="sec-label">Content</p>
      <div class="card-grid">

        <a href="https://youtube.com/@wesfosterpeak" target="_blank" rel="noopener" class="card card-yt">
          <span class="yt-play">▶</span>
          <span class="ctag">YouTube</span>
          <span class="cname">@wesfosterpeak</span>
          <span class="cdesc">Agency growth, AI tools, and building profitable businesses without burning out.</span>
        </a>

        <a href="/blog" class="card">
          <span class="ctag">Blog</span>
          <span class="cname">Blog</span>
          <span class="cdesc">Longer-form writing on agency growth, AI, and building systems that scale.</span>
        </a>

      </div>
    </section>

    <!-- ── Tools ── -->
    <section class="section">
      <p class="sec-label">Tools I Use</p>
      <div class="card">
        <div class="tool-grid">
          <a href="/go/tella" target="_blank" rel="noopener" class="tool-chip">Tella</a>
          <a href="/go/whisprflow" target="_blank" rel="noopener" class="tool-chip">Whispr Flow</a>
          <a href="/go/clickup" target="_blank" rel="noopener" class="tool-chip">ClickUp</a>
          <a href="/go/gohighlevel" target="_blank" rel="noopener" class="tool-chip">GoHighLevel</a>
          <a href="/go/hubstaff" target="_blank" rel="noopener" class="tool-chip">Hubstaff</a>
          <a href="/go/instantly" target="_blank" rel="noopener" class="tool-chip">Instantly</a>
          <a href="/go/searchatlas" target="_blank" rel="noopener" class="tool-chip">Search Atlas</a>
          <a href="/go/skool" target="_blank" rel="noopener" class="tool-chip">Skool</a>
          <a href="/go/appsumo" target="_blank" rel="noopener" class="tool-chip">AppSumo</a>
          <a href="/go/wise" target="_blank" rel="noopener" class="tool-chip">Wise</a>
          <a href="/go/claude" target="_blank" rel="noopener" class="tool-chip">Claude</a>
          <a href="/go/slack" target="_blank" rel="noopener" class="tool-chip">Slack</a>
          <a href="/go/gmail" target="_blank" rel="noopener" class="tool-chip">Gmail</a>
          <a href="/go/obsidian" target="_blank" rel="noopener" class="tool-chip">Obsidian</a>
          <a href="/go/android" target="_blank" rel="noopener" class="tool-chip">Android</a>
          <a href="/go/plexamp" target="_blank" rel="noopener" class="tool-chip">Plexamp</a>
          <a href="/go/brave" target="_blank" rel="noopener" class="tool-chip">Brave</a>
          <a href="/go/firefox" target="_blank" rel="noopener" class="tool-chip">Firefox</a>
          <a href="/go/tailscale" target="_blank" rel="noopener" class="tool-chip">Tailscale</a>
          <a href="/go/signal" target="_blank" rel="noopener" class="tool-chip">Signal</a>
          <a href="/go/protonvpn" target="_blank" rel="noopener" class="tool-chip">ProtonVPN</a>
          <a href="/go/nordvpn" target="_blank" rel="noopener" class="tool-chip">NordVPN</a>
          <a href="/go/zoom" target="_blank" rel="noopener" class="tool-chip">Zoom</a>
          <a href="/go/netlify" target="_blank" rel="noopener" class="tool-chip">Netlify</a>
          <a href="/go/discord" target="_blank" rel="noopener" class="tool-chip">Discord</a>
          <a href="/go/thelounge" target="_blank" rel="noopener" class="tool-chip">The Lounge</a>
          <a href="/go/wsl" target="_blank" rel="noopener" class="tool-chip">WSL</a>
          <a href="/go/sublime" target="_blank" rel="noopener" class="tool-chip">Sublime Text</a>
          <a href="/go/daremote" target="_blank" rel="noopener" class="tool-chip">DaRemote</a>
        </div>
        <p class="aff-note">Some links may be affiliate links — costs you nothing, helps support the work.</p>
      </div>
    </section>

    <!-- ── Social ── -->
    <section class="section">
      <p class="sec-label">Social</p>
      <div class="social-row">
        <a href="https://x.com/realwesfoster" target="_blank" rel="noopener" class="social-chip">X @realwesfoster</a>
        <a href="https://instagram.com/realwesfoster" target="_blank" rel="noopener" class="social-chip">Instagram</a><!-- TODO: confirm handle -->
        <a href="https://facebook.com/realwesfoster" target="_blank" rel="noopener" class="social-chip">Facebook</a>
        <a href="https://linkedin.com/in/wesfoster" target="_blank" rel="noopener" class="social-chip">LinkedIn</a>
        <a href="https://github.com/wesf90" target="_blank" rel="noopener" class="social-chip">GitHub @wesf90</a>
      </div>
    </section>

    <!-- ── About ── -->
    <section class="section">
      <p class="sec-label">About</p>
      <div class="about-grid">
        <p class="about-bio">
          I spent five years in the Army, including a combat deployment to Afghanistan. When I got out,
          I did what most veterans do — I figured I'd find a job. Instead, I built one.
          <br /><br />
          <strong>WESFED</strong> started as a side hustle in 2008 and grew into a $3M+ agency without
          outside funding, without a large team, and without following conventional wisdom. That experience
          — figuring out how to stay lean, stay profitable, and not lose your mind — became the foundation
          for the <strong>PEAK Agency Model</strong>.
          <br /><br />
          Today I help agency operators and digital entrepreneurs do the same thing: build businesses that
          are efficient by design, increasingly powered by AI, and built to last. I run communities, build
          tools, write, and speak. Based in Clarksville, TN.
        </p>
        <ul class="accom-list">
          <li><span class="accom-dot">◆</span> Founded WESFED in 2008 — bootstrapped to $3M+ valuation, still running</li>
          <li><span class="accom-dot">◆</span> US Army Combat Infantry Team Leader — Afghanistan 2010–11</li>
          <li><span class="accom-dot">◆</span> Created the PEAK Agency Model — framework used by operators across the US</li>
          <li><span class="accom-dot">◆</span> Built startup tech that helped raise $1M+ in venture capital, 2014–16</li>
          <li><span class="accom-dot">◆</span> Speaker at marketing and entrepreneurship events since 2016</li>
          <li><span class="accom-dot">◆</span> Top 5% Stack Overflow contributor worldwide</li>
          <li><span class="accom-dot">◆</span> MBA + BS Computer Science — Summa Cum Laude</li>
        </ul>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <span>Wes Foster · Clarksville, TN</span>
    <a href="https://wesfed.com" target="_blank" rel="noopener">wesfed.com</a>
    <a href="mailto:wes@wesfed.com">wes@wesfed.com</a>
  </footer>

  <script>
    document.querySelectorAll('.section').forEach((el, i) => {
      const s = el as HTMLElement;
      s.style.opacity = '0';
      s.style.transform = 'translateY(12px)';
      s.style.transition = 'opacity 0.45s ease, transform 0.45s ease';
      setTimeout(() => {
        s.style.opacity = '1';
        s.style.transform = 'translateY(0)';
      }, 100 + i * 80);
    });
  </script>

</body>
</html>
