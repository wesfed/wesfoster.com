---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wes Foster</title>
  <meta name="description" content="Army veteran, entrepreneur, and agency founder. Building WESFED, ClawDeploy, AI Agent Lab, and Peak Agency Systems from Clarksville, TN." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('wf-theme');
      var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>

  <ThemeToggle />

  <header class="site-header">
    <div class="header-identity">
      <img src="/wes.jpg" alt="Wes Foster" class="site-photo" width="64" height="64" />
      <div>
        <p class="site-name">Wes Foster</p>
        <p class="site-tagline">veteran · marketer · builder · agency founder</p>
      </div>
    </div>
    <p class="header-bio">
      Army veteran and founder of <a href="https://wesfed.com" target="_blank" rel="noopener">WESFED</a>, a digital marketing agency I've been building since 2008. I spend my time helping agency operators grow their MRR, building AI tools for operators, and writing about what I learn along the way.
    </p>
    <p class="header-speaking">
      Available for speaking and podcast appearances &mdash;
      <a href="mailto:wes@wesfed.com">wes@wesfed.com</a> or
      <a href="https://x.com/realwesfoster" target="_blank" rel="noopener">DM on X</a>
    </p>
  </header>

  <main>

    <!-- Building -->
    <section class="section">
      <p class="section-label">Building</p>
      <div class="project-cards">
        <a href="https://clawdeploy.com" target="_blank" rel="noopener" class="project-card">
          <p class="project-card-name">ClawDeploy</p>
          <p class="project-card-desc">OpenClaw-as-a-Service — deploy and manage OpenClaw instances without the headache.</p>
        </a>
        <a href="https://skool.com/aiagentlab" target="_blank" rel="noopener" class="project-card">
          <p class="project-card-name">AI Agent Lab</p>
          <p class="project-card-desc">Free community for agency owners learning to build with AI agents and automation.</p>
        </a>
        <a href="https://peakagencysystems.com/slack26" target="_blank" rel="noopener" class="project-card">
          <p class="project-card-name">Peak Agency Systems</p>
          <p class="project-card-desc">Paid community and coaching for agency operators scaling with the PEAK Model.</p>
        </a>
      </div>
      <div class="coming-soon-row">
        <div class="coming-item">Skills Marketplace <span class="coming-badge">soon</span></div>
        <div class="coming-item">Client Dashboard <span class="coming-badge">soon</span></div>
      </div>
    </section>

    <!-- Content -->
    <section class="section">
      <p class="section-label">Content</p>
      <a href="https://youtube.com/@wesfosterpeak" target="_blank" rel="noopener" class="yt-card">
        <div class="yt-icon">▶</div>
        <div>
          <p class="yt-name">YouTube</p>
          <p class="yt-handle">@wesfosterpeak</p>
          <p class="yt-desc">Agency growth, AI tools, and building profitable businesses without losing your mind.</p>
        </div>
      </a>
      <ul class="content-list">
        <li>
          <span class="content-name"><a href="/blog">Blog</a></span>
          <span class="content-desc">Agency growth, AI, and building things that last</span>
        </li>
        <li>
          <span class="content-name"><a href="https://themondayreset.com" target="_blank" rel="noopener">The Monday Reset</a></span>
          <span class="content-desc">Weekly newsletter for agency operators</span>
        </li>
        <li>
          <span class="content-name"><a href="https://x.com/realwesfoster" target="_blank" rel="noopener">X Threads</a></span>
          <span class="content-desc">Agency growth, AI, entrepreneurship</span>
        </li>
      </ul>
    </section>

    <!-- Credentials -->
    <section class="section">
      <p class="section-label">Credentials</p>
      <ul class="accom-list">
        <li><span class="accom-mark">◆</span> Founded WESFED in 2008 — grown to $3M+ private valuation</li>
        <li><span class="accom-mark">◆</span> US Army Combat Infantry Team Leader — deployed to Afghanistan, 2010–11</li>
        <li><span class="accom-mark">◆</span> Top 5% of software contributors worldwide on StackOverflow</li>
        <li><span class="accom-mark">◆</span> Speaker at conferences and events since 2016</li>
        <li><span class="accom-mark">◆</span> Built startup tech that secured $1M+ in funding, 2014–2016</li>
        <li><span class="accom-mark">◆</span> MBA + BS Computer Science, Summa Cum Laude</li>
      </ul>
    </section>

    <!-- Connect -->
    <section class="section">
      <p class="section-label">Connect</p>
      <div class="connect-chips">
        <a href="https://x.com/realwesfoster" target="_blank" rel="noopener" class="chip">X @realwesfoster</a>
        <a href="https://linkedin.com/in/wesfoster" target="_blank" rel="noopener" class="chip">LinkedIn</a>
        <a href="https://github.com/wesf90" target="_blank" rel="noopener" class="chip">GitHub @wesf90</a>
        <a href="https://facebook.com/realwesfoster" target="_blank" rel="noopener" class="chip">Facebook</a>
        <a href="https://wesfed.com" target="_blank" rel="noopener" class="chip">wesfed.com</a>
        <a href="https://themondayreset.com" target="_blank" rel="noopener" class="chip">themondayreset.com</a>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <span>Wes Foster</span>
    <span>Clarksville, TN</span>
    <a href="https://wesfed.com" target="_blank" rel="noopener">wesfed.com</a>
  </footer>

  <script>
    document.body.classList.add('js-reveal');
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.section').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 50}ms`;
      observer.observe(el);
    });
  </script>

</body>
</html>
